  "_comment": {
    "usage": "gh label create <name> --description <description> --color <color>",
    "setup_script": "for label in $(jq -r '.labels[] | @base64' labels.json); do name=$(echo $label | base64 -d | jq -r '.name'); desc=$(echo $label | base64 -d | jq -r '.description'); color=$(echo $label | base64 -d | jq -r '.color'); gh label create \"$name\" --description \"$desc\" --color \"$color\" --force; done"
